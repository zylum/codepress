#!/usr/bin/env bash
set -euo pipefail
shopt -s nullglob

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="0.4.0"
SOURCE_REPO="https://github.com/zylum/codepress"
CONFIG_FILE=".codepress/system/codepress.md"

# Fallback: some projects use config.md instead of codepress.md
resolve_config() {
  if [[ -f ".codepress/system/codepress.md" ]]; then
    echo ".codepress/system/codepress.md"
  elif [[ -f ".codepress/system/config.md" ]]; then
    echo ".codepress/system/config.md"
  else
    echo "$CONFIG_FILE"
  fi
}

get_codepress_version() {
  local cfg
  cfg=$(resolve_config)
  if [[ -f "$cfg" ]]; then
    grep -m1 "^codepress-version:" "$cfg" 2>/dev/null | sed 's/codepress-version: *//' || echo "0.0.0"
  else
    echo "0.0.0"
  fi
}

get_codepress_source() {
  local cfg
  cfg=$(resolve_config)
  if [[ -f "$cfg" ]]; then
    grep -m1 "^codepress-source:" "$cfg" 2>/dev/null | sed 's/codepress-source: *//' || echo "$SOURCE_REPO"
  else
    echo "$SOURCE_REPO"
  fi
}

usage() {
  cat <<EOF
CodePress v$VERSION — compound product development operating system.

Usage:
  codepress init                  Bootstrap CodePress in this directory
  codepress upgrade               Update .codepress/system/ files from source
  codepress migrate               Migrate from old numbered structure
  codepress status [--json]       Show project health and pending actions
  codepress run [--all]           Execute next pending action (or all)
  codepress watch [seconds]       Watch artefact dir and auto-execute (default 2s)

  codepress galley new <name>     Scaffold a new galley
  codepress galley list           List all galleys with status
  codepress galley move <n> <s>   Set galley status (shaping|approved|delivering|review|done)

  codepress -h|--help             Show this help

See .codepress/system/skills/ for workflow docs.
EOF
}

# ─── System file population (shared by init + migrate) ────────────────────────

# Populate .codepress/system/ with canonical files — from bundled SCRIPT_DIR
# if available, else by cloning the source repo. Returns nonzero on failure.
populate_system_files() {
  if [[ -d "$SCRIPT_DIR/.codepress/system" ]]; then
    echo "→ Copying system files (bundled)..."
    cp -r "$SCRIPT_DIR/.codepress/system/." .codepress/system/
    return 0
  fi

  local src tmp
  src=$(get_codepress_source)
  tmp=$(mktemp -d)
  echo "→ Fetching system files from $src..."
  if git clone --depth 1 --quiet "$src" "$tmp/repo" 2>/dev/null && [[ -d "$tmp/repo/.codepress/system" ]]; then
    cp -r "$tmp/repo/.codepress/system/." .codepress/system/
    rm -rf "$tmp"
    return 0
  fi

  echo "✗ Could not fetch from $src"
  echo "  Clone the repo manually: git clone $src"
  rm -rf "$tmp"
  return 1
}

# ─── Init ────────────────────────────────────────────────────────────────────

cmd_init() {
  echo "CodePress init v$VERSION"
  echo ""

  if [[ -d ".codepress/system" ]]; then
    local v
    v=$(get_codepress_version)
    echo "→ CodePress v$v already bootstrapped here (.codepress/system/ exists)."
    echo "  Run 'codepress upgrade' to update .codepress/system/ files."
    echo "  Run 'codepress migrate' if upgrading from an older structure."
    exit 0
  fi

  echo "→ Bootstrapping CodePress structure..."

  mkdir -p .codepress/system/{skills,templates,hooks}
  mkdir -p .codepress/product/{initiatives,galleys,releases}
  mkdir -p .codepress/knowledge/{decisions,signals,patterns}
  mkdir -p .codepress/views docs src
  mkdir -p .claude/commands

  cat > AGENTS.md << 'EOF'
# CodePress

See `.codepress/system/AGENTS.md` for the full operating manual.
EOF

  populate_system_files || exit 1

  echo ""
  echo "✓ CodePress v$VERSION bootstrapped."
  echo "  Next: populate .codepress/system/codepress.md with your project config"
  echo "  Then: run 'codepress status' to verify"
}

# ─── Utils ─────────────────────────────────────────────────────────────────────

# Merge YAML frontmatter from system file into local file.
# Adds any frontmatter keys present in system that are missing in local.
# Preserves all local content including existing frontmatter values.
merge_frontmatter() {
  local local_file="$1"
  local system_file="$2"
  local lines=() line i key lk sys_key found tmp

  [[ ! -f "$local_file" || ! -f "$system_file" ]] && return

  while IFS= read -r line; do lines+=("$line"); done < "$local_file"

  local fm_start=-1 fm_end=-1 count=0
  for ((i = 0; i < ${#lines[@]}; i++)); do
    [[ "${lines[$i]}" == "---" ]] && { count=$((count + 1)); [[ $count -eq 1 ]] && fm_start=$i; [[ $count -eq 2 ]] && { fm_end=$i; break; }; }
  done
  [[ $fm_end -eq -1 ]] && return

  local local_keys=()
  for ((i = fm_start + 1; i < fm_end; i++)); do
    line="${lines[$i]}"
    [[ -z "$line" || "$line" == \#* ]] && continue
    local_keys+=("${line%%:*}")
  done

  local sys_keys=()
  local in_fm=0
  while IFS= read -r line; do
    [[ "$line" == "---" ]] && { in_fm=$((in_fm + 1)); continue; }
    [[ "$in_fm" -ge 2 ]] && break
    [[ "$in_fm" -eq 1 && -n "$line" && "$line" != \#* ]] && sys_keys+=("$line")
  done < "$system_file"

  [[ ${#sys_keys[@]} -eq 0 ]] && return

  local to_insert=()
  for sys_line in "${sys_keys[@]}"; do
    sys_key="${sys_line%%:*}"
    found=0
    for lk in "${local_keys[@]}"; do
      [[ "$lk" == "$sys_key" ]] && { found=1; break; }
    done
    [[ $found -eq 0 ]] && to_insert+=("$sys_line")
  done

  [[ ${#to_insert[@]} -eq 0 ]] && return

  tmp=$(mktemp)
  {
    for ((i = 0; i < fm_end; i++)); do echo "${lines[$i]}"; done
    for insert in "${to_insert[@]}"; do echo "$insert"; done
    for ((i = fm_end; i < ${#lines[@]}; i++)); do echo "${lines[$i]}"; done
  } > "$tmp"
  mv "$tmp" "$local_file"
  echo "    M  $local_file (frontmatter merged)"
}

# ─── Upgrade ──────────────────────────────────────────────────────────────────

cmd_upgrade() {
  local current
  current=$(get_codepress_version)
  echo "CodePress upgrade v$current → latest"
  echo ""

  if [[ ! -d ".codepress/system" ]]; then
    echo "✗ Not a CodePress project (.codepress/system/ not found). Run 'codepress init' first."
    exit 1
  fi

  local tmp
  tmp=$(mktemp -d)
  trap "rm -rf '$tmp'" EXIT

  local src
  src=$(get_codepress_source)
  echo "→ Fetching CodePress source from $src..."
  if ! git clone --depth 1 --quiet "$src" "$tmp/repo" 2>/dev/null; then
    echo "✗ Could not fetch source. Check your internet connection."
    exit 1
  fi

  local latest
  if [[ -f "$tmp/repo/.codepress/system/codepress.md" ]]; then
    latest=$(grep -m1 "^codepress-version:" "$tmp/repo/.codepress/system/codepress.md" 2>/dev/null | sed 's/codepress-version: *//' || echo "0.0.0")
  else
    echo "✗ No .codepress/system/ found in source repo."
    exit 1
  fi

  echo "→ Current: v$current  Latest: v$latest"
  echo ""

  if [[ "$current" == "$latest" ]]; then
    echo "✓ Already up to date."
    return
  fi

  # Collect all system files from the source repo
  local sys_files=()
  while IFS= read -r f; do sys_files+=("$f"); done < <(cd "$tmp/repo" && find .codepress/system -type f | sed 's|^\./||')

  # ── Phase 1: Analyse ──
  local to_add=() to_update=() to_merge=()
  local local_mods=0

  for f in "${sys_files[@]}"; do
    local target="$f"
    local source="$tmp/repo/$f"
    if [[ ! -f "$target" ]]; then
      to_add+=("$f")
    elif ! diff -q "$target" "$source" &>/dev/null; then
      if [[ "$f" == *templates/* ]]; then
        to_merge+=("$f")
      else
        to_update+=("$f")
      fi
    fi
  done

  echo "→ Changes:"
  if [[ ${#to_add[@]} -gt 0 ]]; then
    for f in "${to_add[@]}"; do echo "    +  $f"; done
  fi
  if [[ ${#to_update[@]} -gt 0 ]]; then
    for f in "${to_update[@]}"; do echo "    U  $f"; done
  fi
  if [[ ${#to_merge[@]} -gt 0 ]]; then
    for f in "${to_merge[@]}"; do echo "    ~  $f (frontmatter merge)"; done
  fi

  if [[ ${#to_add[@]} -eq 0 && ${#to_update[@]} -eq 0 && ${#to_merge[@]} -eq 0 ]]; then
    echo "  (nothing to change)"
    return
  fi

  # ── Phase 2: Apply ──
  echo ""
  read -p "  Apply update? [y/N] " confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "  Aborted."
    return
  fi

  local copied=0 merged=0
  if [[ ${#to_add[@]} -gt 0 ]]; then
    for f in "${to_add[@]}"; do
      mkdir -p "$(dirname "$f")"
      cp "$tmp/repo/$f" "$f"
      copied=$((copied + 1))
    done
  fi
  if [[ ${#to_update[@]} -gt 0 ]]; then
    for f in "${to_update[@]}"; do
      mkdir -p "$(dirname "$f")"
      cp "$tmp/repo/$f" "$f"
      copied=$((copied + 1))
    done
  fi
  if [[ ${#to_merge[@]} -gt 0 ]]; then
    for f in "${to_merge[@]}"; do
      merge_frontmatter "$f" "$tmp/repo/$f" && merged=$((merged + 1))
    done
  fi

  # ── Phase 3: Sync product templates ──
  local sys_templates_dir="$tmp/repo/.codepress/system/templates"
  local product_templates_dir=".codepress/product/templates"
  if [[ -d "$sys_templates_dir" ]]; then
    mkdir -p "$product_templates_dir"
    while IFS= read -r t; do
      local tname="${t#$sys_templates_dir/}"
      local product_target="$product_templates_dir/$tname"
      if [[ -f "$product_target" ]]; then
        merge_frontmatter "$product_target" "$t" && merged=$((merged + 1))
      else
        mkdir -p "$(dirname "$product_target")"
        cp "$t" "$product_target"
        echo "    +  .codepress/product/templates/$tname"
        copied=$((copied + 1))
      fi
    done < <(find "$sys_templates_dir" -type f)
  fi

  echo ""
  echo "✓ Upgraded from v$current to v$latest."
  echo "  $copied file(s) copied, $merged template(s) frontmatter-merged."
}

# ─── Migrate ──────────────────────────────────────────────────────────────────

cmd_migrate() {
  echo "CodePress migrate — reshaping to 3-pillar model"
  echo ""

  if [[ -d ".codepress/system" ]]; then
    echo "  .codepress/system/ already exists — looks already migrated."
    echo "  Run 'codepress upgrade' to refresh system files instead."
    exit 0
  fi

  local has_old=false
  for d in 01-initiatives 02-product 03-delivery 04-patterns 05-domain; do
    [[ -d "$d" ]] && echo "  Found: $d/" && has_old=true
  done
  for f in codepress.md AGENTS.md; do
    [[ -f "$f" ]] && echo "  Found: $f" && has_old=true
  done
  for d in playbooks skills hooks; do
    [[ -d "$d" ]] && echo "  Found: $d/" && has_old=true
  done

  if [[ "$has_old" == false ]]; then
    echo "  No old structure detected. Nothing to migrate."
    exit 0
  fi

  echo ""
  echo "  This moves your PROJECT CONTENT into the 3-pillar model:"
  echo "    01-initiatives/   → .codepress/product/initiatives/"
  echo "    02-product/       → .codepress/product/galleys/"
  echo "    03-delivery/board → .codepress/views/galley-board.md"
  echo "    04-patterns/      → .codepress/knowledge/{signals,patterns}/"
  echo "    05-domain/        → .codepress/knowledge/"
  echo "    codepress.md      → .codepress/system/codepress.md (config preserved)"
  echo ""
  echo "  System files (playbooks, skills, templates, hooks, AGENTS.md) are"
  echo "  REPLACED with canonical v$VERSION files. Stale local copies that"
  echo "  reference the old numbered paths are removed (backed up first)."
  echo ""
  read -p "  Continue? [y/N] " confirm
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Aborted." && exit 0

  mkdir -p .codepress/system .codepress/product/{initiatives,galleys,releases} .codepress/knowledge/{decisions,signals,patterns} .codepress/views docs

  # ── 1. Canonical system files (fixes the old empty-dir bug) ──
  populate_system_files || { echo "✗ Could not populate system files — aborting."; exit 1; }

  # ── 2. Move project content ──
  if [[ -d "01-initiatives" ]]; then
    mv 01-initiatives/* .codepress/product/initiatives/ 2>/dev/null || true
    rm -rf 01-initiatives && echo "  ✓ initiatives"
  fi
  if [[ -d "02-product" ]]; then
    # only galley content, skip old _templates (canonical templates live in system/)
    for item in 02-product/*; do
      [[ -e "$item" ]] || continue
      local base; base=$(basename "$item")
      [[ "$base" == "_templates" ]] && continue
      mv "$item" .codepress/product/galleys/ 2>/dev/null || true
    done
    rm -rf 02-product && echo "  ✓ galleys"
  fi
  if [[ -f "03-delivery/board.md" ]]; then
    mv 03-delivery/board.md .codepress/views/galley-board.md 2>/dev/null || true
  fi
  rm -rf 03-delivery 2>/dev/null && echo "  ✓ delivery board → views"
  if [[ -d "04-patterns" ]]; then
    [[ -d "04-patterns/signals" ]] && mv 04-patterns/signals/* .codepress/knowledge/signals/ 2>/dev/null || true
    [[ -d "04-patterns/patterns" ]] && mv 04-patterns/patterns/* .codepress/knowledge/patterns/ 2>/dev/null || true
    rm -rf 04-patterns && echo "  ✓ patterns + signals → knowledge"
  fi
  if [[ -d "05-domain" ]]; then
    [[ -d "05-domain/decisions" ]] && mv 05-domain/decisions/* .codepress/knowledge/decisions/ 2>/dev/null || true
    rm -rf 05-domain/decisions 2>/dev/null || true
    mv 05-domain/* .codepress/knowledge/ 2>/dev/null || true
    rm -rf 05-domain && echo "  ✓ domain → knowledge"
  fi

  # ── 3. Preserve project config (overwrites canonical placeholder) ──
  if [[ -f "codepress.md" ]]; then
    mv codepress.md .codepress/system/codepress.md 2>/dev/null || true
    # ensure version/source frontmatter from canonical is present
    [[ -d "$SCRIPT_DIR/.codepress/system" ]] && merge_frontmatter .codepress/system/codepress.md "$SCRIPT_DIR/.codepress/system/codepress.md"
    echo "  ✓ project config preserved → system/codepress.md"
  fi

  # ── 4. Back up + remove stale local system docs ──
  local backup=".codepress/system/_migrated-backup"
  for d in playbooks skills hooks; do
    if [[ -d "$d" ]]; then
      mkdir -p "$backup"
      mv "$d" "$backup/$d" 2>/dev/null || true
    fi
  done
  if [[ -f "AGENTS.md" ]] && ! grep -q "See .codepress/system/AGENTS.md" AGENTS.md 2>/dev/null; then
    mkdir -p "$backup"
    cp AGENTS.md "$backup/AGENTS.md" 2>/dev/null || true
  fi
  [[ -d "$backup" ]] && echo "  ✓ stale local system docs backed up → $backup/"

  # ── 5. Root pointer ──
  cat > AGENTS.md << 'EOF'
# CodePress

This project uses CodePress — a compound product development operating system.

See `.codepress/system/AGENTS.md` for the full operating manual.
See `.codepress/system/codepress.md` for project configuration.
EOF

  echo ""
  echo "✓ Migration complete. Review .codepress/system/_migrated-backup/ then delete it."
  echo "  Run 'codepress status' to verify."
}

# ─── Status detector ──────────────────────────────────────────────────────────

detect_pending_actions() {
  local format="${1:-text}"
  local action_count=0
  local out

  # 1. Initiatives ready for shaping (approved or shaping) with no matching Galley
  if [[ -d ".codepress/product/initiatives" ]]; then
    for f in .codepress/product/initiatives/*.md; do
      [[ ! -f "$f" ]] && continue
      local id init_status
      id=$(grep -m1 "^id:" "$f" 2>/dev/null | sed 's/id: *//')
      init_status=$(grep -m1 "^status:" "$f" 2>/dev/null | sed 's/status: *//' || echo "inbox")
      [[ -z "$id" ]] && id=$(basename "$f" .md)

      if [[ "$init_status" == "approved" || "$init_status" == "shaping" ]]; then
        local found=false
        if [[ -d ".codepress/product/galleys" ]]; then
          for g in .codepress/product/galleys/*/galley.md; do
            [[ -f "$g" ]] || continue
            local ref
            ref=$(grep -m1 "^initiative:" "$g" 2>/dev/null | sed 's/initiative: *//' || echo "")
            [[ "$ref" == "$id" ]] && found=true && break
          done
        fi
        if [[ "$found" == false ]]; then
          if [[ "$format" == "json" ]]; then
            out="create-galley|$id|Initiative '$id' is $init_status but no Galley exists"
          else
            echo "  create-galley  $id    Initiative '$id' is $init_status — no Galley yet"
          fi
          action_count=$((action_count + 1))
        fi
      fi
    done
  fi

  # 2. Galleys needing the next workflow step
  if [[ -d ".codepress/product/galleys" ]]; then
    for g in .codepress/product/galleys/*/galley.md; do
      [[ -f "$g" ]] || continue
      local gdir gname gstatus
      gdir=$(dirname "$g")
      gname=$(basename "$gdir")
      [[ "$gname" == _* ]] && continue
      gstatus=$(grep -m1 "^status:" "$g" 2>/dev/null | sed 's/status: *//' || echo "")

      # approved but no slugs → needs split
      if [[ "$gstatus" == "approved" ]]; then
        local slug_count=0
        for s in "$gdir"/slugs/*.md; do
          [[ -f "$s" ]] && slug_count=$((slug_count + 1))
        done
        if [[ "$slug_count" -eq 0 ]]; then
          if [[ "$format" == "json" ]]; then
            out="split-galley|$gname|Galley '$gname' is approved but has no slugs"
          else
            echo "  split-galley  $gname  Galley '$gname' is approved — no slugs yet"
          fi
          action_count=$((action_count + 1))
        fi
      fi

      # delivering with all slugs complete → needs review
      if [[ "$gstatus" == "delivering" ]]; then
        local total=0 complete=0
        for s in "$gdir"/slugs/*.md; do
          [[ ! -f "$s" ]] && continue
          total=$((total + 1))
          local sstatus
          sstatus=$(grep -m1 "^status:" "$s" 2>/dev/null | sed 's/status: *//' || echo "open")
          [[ "$sstatus" == "complete" ]] && complete=$((complete + 1))
        done
        if [[ "$total" -gt 0 && "$complete" -eq "$total" ]]; then
          if [[ "$format" == "json" ]]; then
            out="review|$gname|All slugs complete for '$gname', ready for review"
          else
            echo "  review          $gname  Galley '$gname' — all slugs complete, ready for review"
          fi
          action_count=$((action_count + 1))
        fi
      fi

      # review complete → release + learn, then mark done
      if [[ "$gstatus" == "review" ]]; then
        if [[ "$format" == "json" ]]; then
          out="release+learn|$gname|Galley '$gname' review done, ready to release, capture knowledge, and mark done"
        else
          echo "  release+learn   $gname  Galley '$gname' — review done, ready to release + learn + mark done"
        fi
        action_count=$((action_count + 1))
      fi
    done
  fi

  # 3. Output machine-readable format if requested
  if [[ "$format" == "json" && -n "$out" ]]; then
    echo "$out"
  fi

  if [[ "$action_count" -eq 0 && "$format" != "json" ]]; then
    echo "  (no pending actions — all artefacts are in a consistent state)"
  fi

  return "$action_count"
}

# ─── Status ───────────────────────────────────────────────────────────────────

cmd_status() {
  local json_flag=false
  [[ "${1:-}" == "--json" ]] && json_flag=true

  if [[ "$json_flag" == true ]]; then
    detect_pending_actions json || true
    return
  fi

  echo "CodePress status"
  echo ""

  local v
  v=$(get_codepress_version)
  echo "  Version:  v$v"
  echo ""

  # Initiatives
  local initiatives=0
  if [[ -d ".codepress/product/initiatives" ]]; then local _i; _i=(.codepress/product/initiatives/*.md); initiatives=${#_i[@]}; fi
  echo "  Initiatives:  $initiatives"

  # Galleys
  if [[ -d ".codepress/product/galleys" ]]; then
    local galley_count=0
    echo "  Galleys:"
    for galley in .codepress/product/galleys/*/; do
      name=$(basename "$galley")
      [[ "$name" == _* ]] && continue
      galley_count=$((galley_count + 1))
      gstatus="─"
      if [[ -f "$galley/galley.md" ]]; then
        gstatus=$(grep -m1 "^status:" "$galley/galley.md" 2>/dev/null | sed 's/status: *//' || echo "─")
      fi
      echo "    $name  [$gstatus]"
    done
    [[ "$galley_count" -eq 0 ]] && echo "    (none)"
  fi

  # Releases
  local releases=0
  if [[ -d ".codepress/product/releases" ]]; then local _r; _r=(.codepress/product/releases/*.md); releases=${#_r[@]}; fi
  echo "  Releases:  $releases"

  echo ""

  # Knowledge
  local patterns=0 signals=0 decisions=0
  if [[ -d ".codepress/knowledge/patterns" ]]; then local _p; _p=(.codepress/knowledge/patterns/*.md); patterns=${#_p[@]}; fi
  if [[ -d ".codepress/knowledge/signals" ]]; then local _s; _s=(.codepress/knowledge/signals/*.md); signals=${#_s[@]}; fi
  if [[ -d ".codepress/knowledge/decisions" ]]; then local _d; _d=(.codepress/knowledge/decisions/*.md); decisions=${#_d[@]}; fi
  echo "  Knowledge:  $patterns patterns  |  $signals signals  |  $decisions decisions"

  echo ""

  # Pending actions
  echo "  Pending actions:"
  detect_pending_actions text || true
  echo ""
  echo "  → Run 'codepress run' to execute the next pending action"
  echo ""
  regenerate_boards
}

# ─── Engine dispatch ──────────────────────────────────────────────────────────

resolve_engine() {
  local action="$1"
  local stage=""

  case "$action" in
    create-galley)  stage="shaping" ;;
    split-galley)   stage="split" ;;
    build)          stage="build" ;;
    review)         stage="review" ;;
    release+learn)  stage="release" ;; # primary stage for dispatch
    capture)        stage="capture" ;;
    compound)       stage="compound" ;;
  esac

  if [[ -z "$stage" ]]; then
    echo "claude"
    return
  fi

  if [[ -f ".codepress/system/codepress.md" ]]; then
    local engine
    engine=$(grep -A1 "^  $stage:" ".codepress/system/codepress.md" 2>/dev/null | grep -v "^--$" | tail -1 | sed 's/.*: *//')
    if [[ -n "$engine" ]]; then
      echo "$engine"
      return
    fi
  fi

  echo "claude"
}

dispatch_skill_for() {
  local action="$1"
  local target="$2"
  local engine
  engine=$(resolve_engine "$action")

  case "$action" in
    create-galley)
      echo "  Engine: $engine  →  skills/shape.md  (initiative: $target)"
      ;;
    split-galley)
      echo "  Engine: $engine  →  skills/split.md  (galley: $target)"
      ;;
    review)
      echo "  Engine: $engine  →  skills/review.md  (galley: $target)"
      ;;
    release+learn)
      local release_engine capture_engine
      release_engine=$(resolve_engine "release")
      capture_engine=$(resolve_engine "capture")
      echo "  Engine: $release_engine  →  skills/release.md  (galley: $target)"
      echo "  Engine: $capture_engine  →  skills/review.md  (galley: $target)"
      ;;
  esac
}

# ─── Board regeneration ──────────────────────────────────────────────────────

regenerate_boards() {
  local views=".codepress/views"
  local updated=false

  # Galley board
  if [[ -d ".codepress/product/galleys" && -d "$views" ]]; then
    {
      echo "---"
      echo "kanban-plugin: board"
      echo "---"
      echo ""
      for pair in "Shaping:shaping" "Approved:approved" "Delivering:delivering" "Review:review" "Done:done"; do
        local heading="${pair%%:*}"
        local slug="${pair##*:}"
        echo "## $heading"
        echo ""
        for g in .codepress/product/galleys/*/galley.md; do
          [[ -f "$g" ]] || continue
          local gdir gname gstatus gtitle
          gdir=$(dirname "$g")
          gname=$(basename "$gdir")
          [[ "$gname" == _* ]] && continue
          gstatus=$(grep -m1 "^status:" "$g" 2>/dev/null | sed 's/status: *//' || echo "")
          [[ "$gstatus" != "$slug" ]] && continue
          gtitle=$(grep -m1 "^# Galley:" "$g" 2>/dev/null | sed 's/# Galley: *//' || echo "$gname")
          local checkbox=" "
          [[ "$heading" == "Done" ]] && checkbox="x"
          rel=".codepress/product/galleys/$gname/galley"
          echo "- [$checkbox] [[$rel|$gtitle]]"
        done
        echo ""
      done
      echo "%% kanban:settings"
      echo '```'
      echo '{"kanban-plugin":"board","list-collapse":[false,false,false,false,false]}'
      echo '```'
      echo "%%"
    } > "$views/galley-board.md"
    updated=true
  fi

  # Initiative board
  if [[ -d ".codepress/product/initiatives" && -d "$views" ]]; then
    {
      echo "# Initiative Board"
      echo ""
      echo "Overview of all initiatives — ideas and problems worth solving."
      echo ""
      echo "---"
      echo ""
      echo "## Active"
      echo "| Initiative | Status | Priority |"
      echo "|---|---|---|"
      for f in .codepress/product/initiatives/*.md; do
        [[ -f "$f" ]] || continue
        local iid istatus
        iid=$(grep -m1 "^# Initiative:" "$f" 2>/dev/null | sed 's/# Initiative: *//' || basename "$f" .md)
        istatus=$(grep -m1 "^status:" "$f" 2>/dev/null | sed 's/status: *//' || echo "draft")
        [[ "$istatus" != "draft" && "$istatus" != "completed" ]] && echo "| $iid | $istatus | — |"
      done
      echo ""
      echo "## Backlog"
      echo "| Initiative | Status | Priority |"
      echo "|---|---|---|"
      for f in .codepress/product/initiatives/*.md; do
        [[ -f "$f" ]] || continue
        iid=$(grep -m1 "^# Initiative:" "$f" 2>/dev/null | sed 's/# Initiative: *//' || basename "$f" .md)
        istatus=$(grep -m1 "^status:" "$f" 2>/dev/null | sed 's/status: *//' || echo "draft")
        [[ "$istatus" == "draft" ]] && echo "| $iid | $istatus | — |"
      done
      echo ""
      echo "## Completed"
      echo "| Initiative | Galley | Status |"
      echo "|---|---|---|"
      for f in .codepress/product/initiatives/*.md; do
        [[ -f "$f" ]] || continue
        iid=$(grep -m1 "^# Initiative:" "$f" 2>/dev/null | sed 's/# Initiative: *//' || basename "$f" .md)
        istatus=$(grep -m1 "^status:" "$f" 2>/dev/null | sed 's/status: *//' || echo "draft")
        [[ "$istatus" == "completed" ]] && echo "| $iid | — | $istatus |"
      done
    } > "$views/initiative-board.md"
    updated=true
  fi

  # Release board
  if [[ -d ".codepress/product/releases" && -d "$views" ]]; then
    {
      echo "# Release Board"
      echo ""
      echo "---"
      echo ""
      echo "## Upcoming"
      echo "| Release | Galleys | Target |"
      echo "|---|---|---|"
      echo ""
      echo "## Current"
      echo "| Release | Galleys | Status |"
      echo "|---|---|---|"
      echo ""
      echo "## Shipped"
      echo "| Release | Date | Galleys |"
      echo "|---|---|---|"
    } > "$views/release-board.md"
    updated=true
  fi

  if [[ "$updated" == true ]]; then
    echo "  ✓ Boards regenerated"
  fi
}

execute_action() {
  local action="$1"
  local target="$2"
  local script_dir=".codepress/system"
  local skill_file=""

  case "$action" in
    create-galley)
      skill_file="$script_dir/skills/shape.md"
      echo "  Skill: $skill_file"
      if [[ -f "$skill_file" ]]; then
        cat "$skill_file"
      else
        echo "  ⚠ Skill file not found: $skill_file"
        return 2
      fi
      echo "  → Hand off to $(resolve_engine "$action") with initiative '$target'"
      ;;

    split-galley)
      skill_file="$script_dir/skills/split.md"
      echo "  Skill: $skill_file"
      if [[ -f "$skill_file" ]]; then
        cat "$skill_file"
      else
        echo "  ⚠ Skill file not found: $skill_file"
        return 2
      fi
      echo "  → Hand off to $(resolve_engine "$action") with galley '$target'"
      ;;

    review)
      skill_file="$script_dir/skills/review.md"
      echo "  Skill: $skill_file"
      if [[ -f "$skill_file" ]]; then
        cat "$skill_file"
      else
        echo "  ⚠ Skill file not found: $skill_file"
        return 2
      fi
      echo "  → Hand off to $(resolve_engine "$action") for galley '$target'"
      ;;

    release+learn)
      local release_file="$script_dir/skills/release.md"
      local review_file="$script_dir/skills/review.md"
      echo "  Skill: $release_file"
      [[ -f "$release_file" ]] && cat "$release_file" || echo "  ⚠ File not found: $release_file"
      echo ""
      echo "  Skill: $review_file"
      [[ -f "$review_file" ]] && cat "$review_file" || echo "  ⚠ File not found: $review_file"
      echo "  → Hand off to $(resolve_engine "release") and $(resolve_engine "capture") for galley '$target'"
      ;;
  esac
}

# ─── Run ──────────────────────────────────────────────────────────────────────

cmd_run() {
  local all_flag=false
  [[ "${1:-}" == "--all" ]] && all_flag=true

  local tmpfile
  tmpfile=$(mktemp)
  detect_pending_actions json > "$tmpfile" 2>/dev/null || true
  local pending=()
  while IFS='|' read -r action target desc; do
    [[ -z "$action" ]] && continue
    pending+=("$action|$target|$desc")
  done < "$tmpfile"

  if [[ ${#pending[@]} -eq 0 ]]; then
    echo "No pending actions — all artefacts are in a consistent state."
    rm -f "$tmpfile"
    return
  fi

  if [[ "$all_flag" == false ]]; then
    IFS='|' read -r action target desc <<< "${pending[0]}"
    echo "Next pending action:"
    echo "  $action  $target"
    echo "  $desc"
    echo ""
    echo "Engine dispatch:"
    dispatch_skill_for "$action" "$target"
    echo ""
    read -p "Execute this action? [y/N] " confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
      echo ""
      execute_action "$action" "$target"
      echo ""
      regenerate_boards
      echo ""
      echo "✓ Action dispatched. Run 'codepress status' to see updated state."
    else
      echo "  Skipped."
    fi
  else
    echo "Executing ${#pending[@]} pending action(s)..."
    echo ""
    for entry in "${pending[@]}"; do
      IFS='|' read -r action target desc <<< "$entry"
      echo "─── $action  $target ───"
      echo "  $desc"
      echo ""
      dispatch_skill_for "$action" "$target"
      echo ""
      read -p "Execute? [y/N] " confirm
      if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        execute_action "$action" "$target"
        regenerate_boards
        echo ""
        echo "✓ Done."
      else
        echo "  Skipped."
      fi
      echo ""
    done
    echo "All actions processed."
  fi

  rm -f "$tmpfile"
}

# ─── Watch ─────────────────────────────────────────────────────────────────────

cmd_watch() {
  local watched=".codepress/product"
  local interval="${1:-2}"

  if ! command -v fswatch &>/dev/null; then
    echo "codepress watch requires fswatch."
    echo "  Install: brew install fswatch"
    exit 1
  fi

  echo "CodePress watch — monitoring $watched/ (every ${interval}s)"
  echo "  Press Ctrl+C to stop."
  echo ""

  # Initial scan
  detect_pending_actions text

  fswatch -0 -l "$interval" "$watched" 2>/dev/null | while read -d "" event; do
    echo ""
    echo "─── change detected: $(basename "$(dirname "$event")") ───"
    local count=0
    detect_pending_actions json > /tmp/codepress-pending 2>/dev/null || true
    count=$(grep -c "" /tmp/codepress-pending 2>/dev/null || echo "0")
    if [[ "$count" -gt 0 ]]; then
      echo "  ${count} pending action(s) — running..."
      cmd_run --all < /dev/null
      regenerate_boards
    else
      echo "  No pending actions."
    fi
    echo "  Watching..."
  done
}

# ─── Galley commands ──────────────────────────────────────────────────────────

cmd_galley_new() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "✗ Usage: codepress galley new <name>"
    exit 1
  fi

  local dir=".codepress/product/galleys/$name"
  if [[ -d "$dir" ]]; then
    echo "✗ Galley '$name' already exists at $dir/"
    exit 1
  fi

  mkdir -p "$dir/slugs"

  if [[ -f ".codepress/system/templates/galley.md" ]]; then
    cp ".codepress/system/templates/galley.md" "$dir/galley.md"
    if [[ "$OSTYPE" == "darwin"* ]]; then
      sed -i '' "s/^id: /id: $name/" "$dir/galley.md" 2>/dev/null
    else
      sed -i "s/^id: /id: $name/" "$dir/galley.md" 2>/dev/null
    fi
  else
    cat > "$dir/galley.md" << EOF
---
id: $name
status: shaping
created: $(date +%Y-%m-%d)
---

# Galley: $name
EOF
  fi

  # Create empty review.md
  cat > "$dir/review.md" << EOF
# Review: $name

## Signals captured

## Patterns to promote

## Retrospective
EOF

  echo "✓ Galley '$name' created at $dir/"
  echo "  Next: edit galley.md, then run 'codepress galley move $name shaping'"
}

cmd_galley_list() {
  if [[ ! -d ".codepress/product/galleys" ]]; then
    echo "  No galleys found (.codepress/product/galleys/ does not exist)."
    return
  fi

  local found=false
  for galley in .codepress/product/galleys/*/; do
    name=$(basename "$galley")
    [[ "$name" == _* ]] && continue
    found=true
    status="─"
    if [[ -f "$galley/galley.md" ]]; then
      status=$(grep -m1 "^status:" "$galley/galley.md" 2>/dev/null | sed 's/status: *//' || echo "─")
    fi
    printf "  %-30s [%s]\n" "$name" "$status"
  done

  [[ "$found" == false ]] && echo "  (no galleys yet — use 'codepress galley new <name>')"
}

cmd_galley_move() {
  local name="${1:-}"
  local target="${2:-}"
  local valid_statuses="shaping approved delivering review done"

  if [[ -z "$name" || -z "$target" ]]; then
    echo "✗ Usage: codepress galley move <name> <status>"
    echo "  Status: shaping | approved | delivering | review | done"
    exit 1
  fi

  if ! echo "$valid_statuses" | grep -wq "$target"; then
    echo "✗ Invalid status '$target'. Valid: shaping approved delivering review done"
    exit 1
  fi

  local file=".codepress/product/galleys/$name/galley.md"
  if [[ ! -f "$file" ]]; then
    echo "✗ Galley '$name' not found at $file"
    exit 1
  fi

  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "s/^status:.*/status: $target/" "$file"
  else
    sed -i "s/^status:.*/status: $target/" "$file"
  fi

  echo "✓ Galley '$name' moved to [$target]"
  regenerate_boards
}

cmd_galley() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    new) cmd_galley_new "$@" ;;
    list) cmd_galley_list "$@" ;;
    move) cmd_galley_move "$@" ;;
    *) echo "Usage: codepress galley new|list|move"; exit 1 ;;
  esac
}

# ─── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  init) cmd_init ;;
  upgrade) cmd_upgrade ;;
  migrate) cmd_migrate ;;
  status) shift; cmd_status "$@" ;;
  run) shift; cmd_run "$@" ;;
  watch) shift; cmd_watch "$@" ;;
  galley) shift; cmd_galley "$@" ;;
  -h|--help|"") usage ;;
  *) echo "Unknown: $1"; usage; exit 1 ;;
esac
