#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="0.1.0"
SOURCE_REPO="https://github.com/zylum/codepress"
CONFIG_FILE=".codepress/system/codepress.md"

get_codepress_version() {
  if [[ -f "$CONFIG_FILE" ]]; then
    grep -m1 "^codepress-version:" "$CONFIG_FILE" 2>/dev/null | sed 's/codepress-version: *//' || echo "0.0.0"
  else
    echo "0.0.0"
  fi
}

get_codepress_source() {
  if [[ -f "$CONFIG_FILE" ]]; then
    grep -m1 "^codepress-source:" "$CONFIG_FILE" 2>/dev/null | sed 's/codepress-source: *//' || echo "$SOURCE_REPO"
  else
    echo "$SOURCE_REPO"
  fi
}

usage() {
  cat <<EOF
CodePress v$VERSION — compound product development operating system.

Usage:
  codepress init                  Bootstrap CodePress in this directory
  codepress upgrade               Update .codepress/system/ files from source
  codepress migrate               Migrate from old numbered structure
  codepress status                Show project health at a glance

  codepress galley new <name>     Scaffold a new galley
  codepress galley list           List all galleys with status
  codepress galley move <n> <s>   Set galley status (shaping|approved|delivering|review|done)

  codepress -h|--help             Show this help

See .codepress/system/playbooks/ and .codepress/system/skills/ for workflow docs.
EOF
}

# ─── Init ────────────────────────────────────────────────────────────────────

cmd_init() {
  echo "CodePress init v$VERSION"
  echo ""

  if [[ -d ".codepress/system" ]]; then
    local v
    v=$(get_codepress_version)
    echo "→ CodePress v$v already bootstrapped here (.codepress/system/ exists)."
    echo "  Run 'codepress upgrade' to update .codepress/system/ files."
    echo "  Run 'codepress migrate' if upgrading from an older structure."
    exit 0
  fi

  echo "→ Bootstrapping CodePress structure..."

  mkdir -p .codepress/system/{playbooks,skills,templates,hooks}
  mkdir -p .codepress/product/{initiatives,galleys,releases}
  mkdir -p .codepress/knowledge/{decisions,signals,patterns}
  mkdir -p .codepress/views docs src

  cat > AGENTS.md << 'EOF'
# CodePress

See `.codepress/system/AGENTS.md` for the full operating manual.
EOF

  # Copy .codepress/system/ — from bundled files or source repo
  if [[ -d "$SCRIPT_DIR/.codepress/system" ]]; then
    echo "→ Copying system files (bundled)..."
    cp -r "$SCRIPT_DIR/.codepress/system/." .codepress/system/
  else
    local src tmp
    src=$(get_codepress_source)
    tmp=$(mktemp -d)
    echo "→ Fetching system files from $src..."
    if git clone --depth 1 --quiet "$src" "$tmp/repo" 2>/dev/null && [[ -d "$tmp/repo/.codepress/system" ]]; then
      cp -r "$tmp/repo/.codepress/system/." .codepress/system/
    else
      echo "✗ Could not fetch from $src"
      echo "  Clone the repo manually: git clone $src"
      rm -rf "$tmp"
      exit 1
    fi
    rm -rf "$tmp"
  fi

  echo ""
  echo "✓ CodePress v$VERSION bootstrapped."
  echo "  Next: populate .codepress/system/codepress.md with your project config"
  echo "  Then: run 'codepress status' to verify"
}

# ─── Upgrade ──────────────────────────────────────────────────────────────────

cmd_upgrade() {
  local current
  current=$(get_codepress_version)
  echo "CodePress upgrade v$current → latest"
  echo ""

  if [[ ! -d ".codepress/system" ]]; then
    echo "✗ Not a CodePress project (.codepress/system/ not found). Run 'codepress init' first."
    exit 1
  fi

  local tmp
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' EXIT

  local src
  src=$(get_codepress_source)
  echo "→ Fetching CodePress source from $src..."
  if ! git clone --depth 1 --quiet "$src" "$tmp/repo" 2>/dev/null; then
    echo "✗ Could not fetch source. Check your internet connection."
    exit 1
  fi

  local latest
  if [[ -f "$tmp/repo/.codepress/system/codepress.md" ]]; then
    latest=$(grep -m1 "^codepress-version:" "$tmp/repo/.codepress/system/codepress.md" 2>/dev/null | sed 's/codepress-version: *//' || echo "0.0.0")
  else
    echo "✗ No .codepress/system/ found in source repo."
    exit 1
  fi

  echo "→ Current: v$current  Latest: v$latest"
  echo ""

  if [[ "$current" == "$latest" ]]; then
    echo "✓ Already up to date."
    return
  fi

  # Check for local modifications in .codepress/system/
  local local_mods=0
  while IFS= read -r f; do
    if [[ -f "$f" ]]; then
      remote="$tmp/repo/$f"
      if [[ -f "$remote" ]] && ! diff -q "$f" "$remote" &>/dev/null; then
        if [[ "$local_mods" -eq 0 ]]; then
          echo "  Locally modified files (will not be overwritten):"
        fi
        echo "    $f"
        local_mods=$((local_mods + 1))
      fi
    fi
  done < <(cd "$tmp/repo" && find .codepress/system -type f | sed 's|^\./||')

  echo ""
  echo "→ Files to add/update:"
  local count=0
  while IFS= read -r f; do
    local target="$f"
    local source="$tmp/repo/$f"
    if [[ -f "$target" ]]; then
      if ! diff -q "$target" "$source" &>/dev/null; then
        echo "    U  $f"
        count=$((count + 1))
      fi
    else
      echo "    +  $f"
      count=$((count + 1))
    fi
  done < <(cd "$tmp/repo" && find .codepress/system -type f | sed 's|^\./||')

  if [[ "$count" -eq 0 && "$local_mods" -eq 0 ]]; then
    echo "  (nothing to change)"
    return
  fi

  echo ""
  read -p "  Apply update? [y/N] " confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "  Aborted."
    return
  fi

  # Copy new/changed files, skip locally modified ones
  local copied=0
  while IFS= read -r f; do
    local target="$f"
    local source="$tmp/repo/$f"
    if [[ -f "$target" ]]; then
      if diff -q "$target" "$source" &>/dev/null; then
        continue
      fi
    fi
    mkdir -p "$(dirname "$target")"
    cp "$source" "$target"
    copied=$((copied + 1))
  done < <(cd "$tmp/repo" && find .codepress/system -type f | sed 's|^\./||')

  echo ""
  echo "✓ Upgraded from v$current to v$latest ($copied files updated)."
  if [[ "$local_mods" -gt 0 ]]; then
    echo "  ⚠ $local_mods local file(s) left unchanged. Review manually:"
    echo "    diff -u <local> <system> to merge changes."
  fi
}

# ─── Migrate ──────────────────────────────────────────────────────────────────

cmd_migrate() {
  echo "CodePress migrate — reshaping to 3-pillar model"
  echo ""

  local has_old=false
  for d in 01-initiatives 02-product 03-delivery 04-patterns 05-domain; do
    [[ -d "$d" ]] && echo "  Found: $d/" && has_old=true
  done

  if [[ "$has_old" == false ]]; then
    echo "  No old structure detected. Already using 3-pillar model."
    exit 0
  fi

  echo ""
  echo "  This rewrites the old numbered structure into:"
  echo "    01-initiatives/   → .codepress/product/initiatives/"
  echo "    02-product/       → .codepress/product/galleys/"
  echo "    03-delivery/      → .codepress/views/"
  echo "    04-patterns/      → .codepress/knowledge/patterns/ + .codepress/knowledge/signals/"
  echo "    05-domain/        → .codepress/knowledge/"
  echo "    codepress.md      → .codepress/system/codepress.md"
  echo "    AGENTS.md         → .codepress/system/AGENTS.md"
  echo "    playbooks/        → .codepress/system/playbooks/"
  echo "    skills/           → .codepress/system/skills/"
  echo ""
  read -p "  Continue? [y/N] " confirm
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Aborted." && exit 0

  mkdir -p .codepress/system/{playbooks,skills,templates,hooks} .codepress/product/{initiatives,galleys,releases} .codepress/knowledge/{decisions,signals,patterns} .codepress/views docs

  [[ -d "01-initiatives" ]] && mv 01-initiatives/* .codepress/product/initiatives/ 2>/dev/null && rm -rf 01-initiatives && echo "  ✓ 01-initiatives → .codepress/product/initiatives/"
  [[ -d "02-product" ]] && mv 02-product/* .codepress/product/galleys/ 2>/dev/null && rm -rf 02-product && echo "  ✓ 02-product → .codepress/product/galleys/"
  [[ -f "03-delivery/board.md" ]] && mv 03-delivery/board.md .codepress/views/galley-board.md 2>/dev/null && rm -rf 03-delivery && echo "  ✓ 03-delivery → .codepress/views/"
  [[ -d "04-patterns" ]] && mv 04-patterns/* .codepress/knowledge/ 2>/dev/null; [[ -d "04-patterns" ]] && rm -rf 04-patterns && echo "  ✓ 04-patterns → .codepress/knowledge/"
  [[ -d "05-domain" ]] && mv 05-domain/* .codepress/knowledge/ 2>/dev/null && rm -rf 05-domain && echo "  ✓ 05-domain → .codepress/knowledge/"
  [[ -f "codepress.md" ]] && mv codepress.md .codepress/system/codepress.md 2>/dev/null && echo "  ✓ codepress.md → .codepress/system/codepress.md"
  [[ -f "AGENTS.md" ]] && mv AGENTS.md .codepress/system/AGENTS.md 2>/dev/null && echo "  ✓ AGENTS.md → .codepress/system/AGENTS.md"
  [[ -d "playbooks" && ! -d ".codepress/system/playbooks" ]] && mv playbooks .codepress/system/playbooks 2>/dev/null && echo "  ✓ playbooks → .codepress/system/playbooks/"
  [[ -d "skills" && ! -d ".codepress/system/skills" ]] && mv skills .codepress/system/skills 2>/dev/null && echo "  ✓ skills → .codepress/system/skills/"
  [[ -d "hooks" && ! -d ".codepress/system/hooks" ]] && mv hooks .codepress/system/hooks 2>/dev/null && echo "  ✓ hooks → .codepress/system/hooks/"

  cat > AGENTS.md << 'EOF'
# CodePress

See `.codepress/system/AGENTS.md` for the full operating manual.
EOF

  echo ""
  echo "✓ Migration complete. Run 'codepress status' to verify."
}

# ─── Status ───────────────────────────────────────────────────────────────────

cmd_status() {
  echo "CodePress status"
  echo ""

  local v
  v=$(get_codepress_version)
  echo "  Version:  v$v"
  echo ""

  # Galleys
  if [[ -d ".codepress/product/galleys" ]]; then
    local galley_count=0
    echo "  Galleys:"
    for galley in .codepress/product/galleys/*/; do
      name=$(basename "$galley")
      [[ "$name" == _* ]] && continue
      galley_count=$((galley_count + 1))
      status="─"
      if [[ -f "$galley/galley.md" ]]; then
        status=$(grep -m1 "^status:" "$galley/galley.md" 2>/dev/null | sed 's/status: *//' || echo "─")
      fi
      echo "    $name  [$status]"
    done
    [[ "$galley_count" -eq 0 ]] && echo "    (none)"
  else
    echo "  Galleys:  (.codepress/product/galleys/ not found)"
  fi

  echo ""

  # Knowledge
  local patterns=0 signals=0 decisions=0
  [[ -d ".codepress/knowledge/patterns" ]] && patterns=$(ls .codepress/knowledge/patterns/*.md 2>/dev/null | grep -v _template.md | wc -l | tr -d ' ')
  [[ -d ".codepress/knowledge/signals" ]] && signals=$(ls .codepress/knowledge/signals/*.md 2>/dev/null | wc -l | tr -d ' ')
  [[ -d ".codepress/knowledge/decisions" ]] && decisions=$(ls .codepress/knowledge/decisions/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo "  Knowledge:  $patterns patterns  |  $signals signals  |  $decisions decisions"

  # Initiatives
  local initiatives=0
  [[ -d ".codepress/product/initiatives" ]] && initiatives=$(ls .codepress/product/initiatives/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo "  Initiatives:  $initiatives"

  # Releases
  local releases=0
  [[ -d ".codepress/product/releases" ]] && releases=$(ls .codepress/product/releases/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo "  Releases:  $releases"
}

# ─── Galley commands ──────────────────────────────────────────────────────────

cmd_galley_new() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "✗ Usage: codepress galley new <name>"
    exit 1
  fi

  local dir=".codepress/product/galleys/$name"
  if [[ -d "$dir" ]]; then
    echo "✗ Galley '$name' already exists at $dir/"
    exit 1
  fi

  mkdir -p "$dir/slugs"

  if [[ -f ".codepress/system/templates/galley.md" ]]; then
    cp ".codepress/system/templates/galley.md" "$dir/galley.md"
    # Fill in the id
    if [[ "$OSTYPE" == "darwin"* ]]; then
      sed -i '' "s/^id: /id: $name/" "$dir/galley.md" 2>/dev/null
    else
      sed -i "s/^id: /id: $name/" "$dir/galley.md" 2>/dev/null
    fi
  else
    cat > "$dir/galley.md" << EOF
---
id: $name
status: shaping
created: $(date +%Y-%m-%d)
---

# Galley: $name
EOF
  fi

  # Create empty review.md
  cat > "$dir/review.md" << EOF
# Review: $name

## Signals captured

## Patterns to promote

## Retrospective
EOF

  echo "✓ Galley '$name' created at $dir/"
  echo "  Next: edit galley.md, then run 'codepress galley move $name shaping'"
}

cmd_galley_list() {
  if [[ ! -d ".codepress/product/galleys" ]]; then
    echo "  No galleys found (.codepress/product/galleys/ does not exist)."
    return
  fi

  local found=false
  for galley in .codepress/product/galleys/*/; do
    name=$(basename "$galley")
    [[ "$name" == _* ]] && continue
    found=true
    status="─"
    if [[ -f "$galley/galley.md" ]]; then
      status=$(grep -m1 "^status:" "$galley/galley.md" 2>/dev/null | sed 's/status: *//' || echo "─")
    fi
    printf "  %-30s [%s]\n" "$name" "$status"
  done

  [[ "$found" == false ]] && echo "  (no galleys yet — use 'codepress galley new <name>')"
}

cmd_galley_move() {
  local name="${1:-}"
  local target="${2:-}"
  local valid_statuses="shaping approved delivering review done"

  if [[ -z "$name" || -z "$target" ]]; then
    echo "✗ Usage: codepress galley move <name> <status>"
    echo "  Status: shaping | approved | delivering | review | done"
    exit 1
  fi

  if ! echo "$valid_statuses" | grep -wq "$target"; then
    echo "✗ Invalid status '$target'. Valid: shaping approved delivering review done"
    exit 1
  fi

  local file=".codepress/product/galleys/$name/galley.md"
  if [[ ! -f "$file" ]]; then
    echo "✗ Galley '$name' not found at $file"
    exit 1
  fi

  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "s/^status:.*/status: $target/" "$file"
  else
    sed -i "s/^status:.*/status: $target/" "$file"
  fi

  echo "✓ Galley '$name' moved to [$target]"
}

cmd_galley() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    new) cmd_galley_new "$@" ;;
    list) cmd_galley_list "$@" ;;
    move) cmd_galley_move "$@" ;;
    *) echo "Usage: codepress galley new|list|move"; exit 1 ;;
  esac
}

# ─── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  init) cmd_init ;;
  upgrade) cmd_upgrade ;;
  migrate) cmd_migrate ;;
  status) cmd_status ;;
  galley) shift; cmd_galley "$@" ;;
  -h|--help|"") usage ;;
  *) echo "Unknown: $1"; usage; exit 1 ;;
esac
